  "lyrics": {
    "openings": [
      "Я нашёл твой след в холодном свете дня",
      "Мы ехали сквозь город до утра",
      "На крышах тихо таяла луна",
      "Твой голос плыл из старого окна",
      "Мы оставляли письма на стене",
      "В пустом метро звучала тишина",
      "Я видел сны о розовой зиме",
      "На перекрёстке гасла полоса"
    ],
    "middles": [
      "и каждый миг звучал почти как песня",
      "а радио шептало нам ответ",
      "но лето уходило слишком быстро",
      "и город растворялся в синем сне",
      "мы верили, что ночь нас не отпустит",
      "и свет витрин дрожал в твоих глазах",
      "как будто всё могло начать сначала",
      "как будто не закончится рассвет"
    ],
    "choruses": [
      "Держи меня, пока горят огни",
      "Вернись ко мне в неоновую ночь",
      "Лети со мной над крышами земли",
      "Не отпускай, пока звучит любовь",
      "Пой громче, пусть услышит этот город",
      "Мы будем там, где начинается свет",
      "Останься здесь, пока не станет поздно",
      "Смотри вперёд, назад дороги нет"
    ],
    "endings": [
      "и я запомню этот звук",
      "пока не кончится ночь",
      "и небо станет золотым",
      "когда погаснут фонари",
      "и мы исчезнем без следа",
      "но песня останется с нами",
      "там, где начинается утро",
      "там, где нас никто не найдёт"
    ]
  },
